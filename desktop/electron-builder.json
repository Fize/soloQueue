{
  "appId": "com.xiaobaitu.soloqueue",
  "productName": "SoloQueue",
  "directories": {
    "output": "dist-desktop"
  },
  "files": [
    "main.js",
    "preload.js",
    "package.json",
    "dist/**/*"
  ],
  "extraResources": [
    {
      "from": "../soloqueue",
      "to": "soloqueue"
    }
  ],
  "mac": {
    "target": "dmg",
    "category": "public.app-category.developer-tools"
  },
  "win": {
    "target": "nsis"
  },
  "linux": {
    "target": "AppImage"
  }
}
